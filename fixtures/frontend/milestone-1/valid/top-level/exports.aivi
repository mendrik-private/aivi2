type Status = Idle | Busy

type Status -> Text
func statusLabel = status => status
 ||> Idle -> "Idle"
 ||> Busy -> "Busy"

value main =
    <Window title="Milestone 1">
        <Box orientation="vertical" spacing={12}>
            <Label text="Frontend fixture corpus" />
            <Label text={statusLabel Idle} />
        </Box>
    </Window>

export (statusLabel, main)
