type User = User Text Int

type LoadState =
  | NotAsked
  | Loaded User
  | Failed Text

value loadedName:Text state:LoadState =>
    state
     ||> NotAsked => "waiting"
     ||> Loaded (User name _) => name
     ||> Failed message => message

value firstOfPair:Int pair:(Int, Int) =>
    pair
     ||> (first, _) => first
