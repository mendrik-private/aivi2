type User =
  | User Text Int

type LoadState =
  | NotAsked
  | Loaded User
  | Failed Text

type LoadState -> Text
func loadedName = state=> state ||> NotAsked             -> "waiting"
 ||> Loaded (User name _) -> name
 ||> Failed message       -> message

type (Int, Int) -> Int
func firstOfPair = pair=> pair ||> (first, _) -> first
