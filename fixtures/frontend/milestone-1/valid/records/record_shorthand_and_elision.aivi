use aivi.defaults (Option)

type Profile = {
    name: Text,
    nickname: Option Text,
    bio: Option Text
}

value name = "Ada"
value nickname = Some "Countess"

value richProfile : Profile = {
    name,
    nickname
}

value minimalProfile : Profile = {
    name: "Grace"
}

type Profile -> Text
func profileName = profile=> profile ||> { name, nickname } -> name
