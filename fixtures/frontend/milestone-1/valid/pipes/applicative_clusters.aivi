type UserDraft =
  UserDraft Text Text Int

type NamePair =
  NamePair Text Text

signal nameText = "Ada"
signal emailText = "ada@example.com"
signal ageValue = 36
signal firstName = "Ada"
signal lastName = "Lovelace"

signal validatedUser =
 &|> nameText
 &|> emailText
 &|> ageValue
  |> UserDraft

signal namePair =
 &|> firstName
 &|> lastName
  |> NamePair

signal tupledNames =
 &|> firstName
 &|> lastName
