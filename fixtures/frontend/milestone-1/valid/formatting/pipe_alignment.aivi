type Pair = Pair Text Text

type SaveState =
  | Saved
  | Dirty Text

signal documentTitle = "Notes"
signal documentBody = "Hello"

signal draft =
   &|> documentTitle
 &|> documentBody
    |> Pair

value label:Text state:SaveState =>
  state
    ||> Saved => "saved"
   ||> Dirty message => "dirty {message}"
