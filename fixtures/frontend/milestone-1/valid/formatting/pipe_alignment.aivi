type Pair =
  | Pair Text Text

type SaveState =
  | Saved
  | Dirty Text

signal documentTitle = "Notes"
signal documentBody = "Hello"

signal draft =
 &|> documentTitle
 &|> documentBody
  |> Pair

type SaveState -> Text
func label = state=> state ||> Saved         -> "saved"
 ||> Dirty message -> "dirty {message}"
