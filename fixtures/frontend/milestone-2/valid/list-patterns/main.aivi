type Summary = {
    empty: Int,
    single: Int,
    many: Int,
    count: Int
}

type List Int => Int
func listLength = values=> values ||> []             -> 0
 ||> [_head, ...xs] -> 1 + listLength xs

type List Int => Int
func prefixScore = values=> values ||> []                       -> 0
 ||> [first]                  -> first
 ||> [first, second, ...rest] -> first + second + listLength rest

value summary : Summary = {
    empty: prefixScore [],
    single: prefixScore [7],
    many: prefixScore [4, 5, 6],
    count: listLength [4, 5, 6]
}

export summary
