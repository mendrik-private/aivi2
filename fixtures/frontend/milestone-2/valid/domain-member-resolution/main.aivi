domain Duration over Int = {
    literal ms : Int -> Duration
    type Int -> Duration
    make
}

domain Count over Int = {
    type Int -> Count
    make
}

domain NonEmpty A over List A = {
    type A -> NonEmpty A
    singleton
    type NonEmpty A -> A
    head
}

value delay : Duration = make 250
value delayMillis : Int = delay.carrier
value literalMillis : Int = (250ms).carrier
value first : Int = head (singleton 1)

export first
