domain Duration over Int
    suffix ms : Int = value => Duration value
    make : Int -> Duration
    millis : Duration -> Int
    millis = duration => duration.carrier

domain Count over Int
    make : Int -> Count

domain NonEmpty A over List A
    singleton : A -> NonEmpty A
    head : NonEmpty A -> A

value delay : Duration = make 250
value delayMillis : Int = millis delay
value literalMillis : Int = millis 250ms
value first : Int = head (singleton 1)

export first
