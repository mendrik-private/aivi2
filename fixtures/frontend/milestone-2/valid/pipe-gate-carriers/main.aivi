type User = {
    active: Bool,
    email: Text
}

type Session = {
    user: User
}

value seed:User = { active: True, email: "ada@example.com" }

value maybeActive:Option User =
    seed
     ?|> .active

signal sessions:Signal Session = { user: seed }

signal activeUsers:Signal User =
    sessions
     |> .user
     ?|> .active
