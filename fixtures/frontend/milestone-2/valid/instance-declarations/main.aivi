class Eq A
(==): A -> A -> Bool

type Blob = Blob Bytes

fun blobEquals: Bool left: Blob right: Blob =>
  True

instance Eq Blob
(==) left right = blobEquals left right

fun sameBlob: Bool left: Blob right: Blob =>
  left == right

class Compare A
same: A -> A -> Bool

type Label = Label Text

instance Compare Label
same left right = left == right
