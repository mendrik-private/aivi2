type Screen =
  | Loading
  | Ready Text
  | Failed Text

type NamePair = NamePair Text Text

value first = Some "Ada"
value last = None

value maybePair:Option NamePair =
 &|> first
 &|> last
  |> NamePair

value okFirst = Ok "Ada"
value errLast = Err "missing"

value resultPair:Result Text NamePair =
 &|> okFirst
 &|> errLast
  |> NamePair

value current:Screen = Loading

value maybeLabel:Option Text =
    current
     ||> Loading => None
     ||> Ready title => Some title
     ||> Failed reason => Some reason

value resultLabel:Result Text Text =
    current
     ||> Loading => Ok "loading"
     ||> Ready title => Ok title
     ||> Failed reason => Err reason
