use aivi (
    Ordering
    Option
    Result
    Validation
    Signal
    Task
    Less
    Equal
    Greater
    Some
    None
    Ok
    Err
    Valid
    Invalid
)

use aivi.prelude (
    Int
    Bool
    Text
    List
    Eq
    Default
    Functor
    Ord
    Semigroup
    Monoid
    Bifunctor
    Traversable
    Filterable
    Applicative
    Monad
    Foldable
    getOrElse
    withDefault
    length
    head
    min
    max
    minOf
    join
)

type NameSignal = Signal Text

type CountTask = Task Text Int

type CheckedName =
  | Validation Text Text

value maybeName: Option Text = Some "Ada"
value missingName: Option Text = None
value chosenName: Text = getOrElse "guest" missingName
value okCount: Result Text Int = Ok 2
value errCount: Result Text Int = Err "missing"
value chosenCount: Int = withDefault 0 okCount
value checkedName: CheckedName = Valid "Ada"

value nameCount: Int =
    length [
        "Ada",
        "Grace"
    ]

value firstName: Option Text =
    head [
        "Ada",
        "Grace"
    ]

value smaller:Bool left:Int right:Int =>
    left < right

value keepSmall:(Option Int) x:Int =>
    x < 3
     T|> Some x
     F|> None

value addOne:Int x:Int =>
    x + 1

value punctuate:Text x:Text =>
    append x "!"

value leastCount: Int = min smaller 4 2
value greatestCount: Int = max smaller 4 2
value explicitLess: Ordering = Less

value leastOfCounts: Int =
    minOf smaller 5 [
        3,
        4
    ]

value labels: Text =
    join ", " [
        "Ada",
        "Grace"
    ]

value orderedCount: Ordering = compare 1 2
value combinedLabel: Text = append "Ada" " Lovelace"
value emptyLabels: Text = empty
value mappedOk: Result Text Int = bimap punctuate addOne (Ok 1)

value traversedCounts: Option (List Int) =
    traverse keepSmall [
        1,
        2
    ]

value filteredCounts: List Int =
    filterMap keepSmall [
        1,
        3,
        2
    ]

value sameCount: Bool = chosenCount == 2
