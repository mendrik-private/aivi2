use aivi (
    Ordering
    Option
    Result
    Validation
    Signal
    Task
    Less
    Equal
    Greater
    Some
    None
    Ok
    Err
    Valid
    Invalid
)

use aivi.prelude (
    Int
    Bool
    Text
    List
    Eq
    Default
    Functor
    Ord
    Semigroup
    Monoid
    Bifunctor
    Traversable
    Filterable
    Applicative
    Monad
    Foldable
    getOrElse
    foldOption
    mapOr
    isSomeAnd
    withDefault
    length
    head
    indexed
    mapWithIndex
    reduceWithIndex
    min
    max
    minOf
    join
)

use aivi.matrix (
    Matrix
    MatrixError
    init
    rows
)

type NameSignal = Signal Text

type CountTask = Task Text Int

type CheckedName =
  Validation Text Text

value maybeName : Option Text = Some "Ada"
value missingName : Option Text = None
value chosenName : Text = getOrElse "guest" missingName
value okCount : Result Text Int = Ok 2
value errCount : Result Text Int = Err "missing"
value chosenCount : Int = withDefault 0 okCount
value checkedName : CheckedName = Valid "Ada"

value nameCount : Int =
    length [
        "Ada",
        "Grace"
    ]

value firstName : Option Text =
    head [
        "Ada",
        "Grace"
    ]

type Int -> Int -> Bool
func smaller = left right =>
    left < right

type Int -> (Option Int)
func keepSmall = x => x < 3
 T|> Some x
 F|> None

type Int -> Int
func addOne = x =>
    x + 1

type Int -> Bool
func smallerThanThree = x =>
    x < 3

type Int -> Int -> Int
func addIndex = index item =>
    index + item

type Int -> Int -> Int -> Int
func addIndexedTotal = total index item =>
    total + index + item

type Int -> Int -> Int
func add = total item =>
    total + item

type Int -> Int -> Int
func gridCell = x y =>
    x + y * 10

type Text -> Text
func punctuate = x =>
    append x "!"

value leastCount : Int = min smaller 4 2
value greatestCount : Int = max smaller 4 2
value explicitLess : Ordering = Less

value leastOfCounts : Int =
    minOf smaller 5 [
        3,
        4
    ]

value labels : Text =
    join ", " [
        "Ada",
        "Grace"
    ]

value orderedCount : Ordering = compare 1 2
value combinedLabel : Text = append "Ada" " Lovelace"
value emptyLabels : Text = empty
value mappedOk : Result Text Int = bimap punctuate addOne (Ok 1)

value traversedCounts : Option (List Int) =
    traverse keepSmall [
        1,
        2
    ]

value filteredCounts : List Int =
    filterMap keepSmall [
        1,
        3,
        2
    ]

value foldedMaybeName : Text = foldOption "guest" punctuate maybeName
value mappedMaybeCount : Int = mapOr 0 addOne (Some 2)
value maybeCountSmall : Bool = isSomeAnd smallerThanThree (Some 2)

value indexedLabels : List (Int, Text) =
    indexed [
        "Ada",
        "Grace"
    ]

value indexedCounts : List Int =
    mapWithIndex addIndex [
        10,
        20,
        30
    ]

value countedWithIndices : Int =
    reduceWithIndex addIndexedTotal 0 [
        10,
        20,
        30
    ]

value mappedGridRows : Result MatrixError (List (List Int)) = init 2 2 gridCell
 ||> Err error -> Err error
 ||> Ok matrix -> Ok (rows (map addOne matrix))

value reducedGridTotal : Result MatrixError Int = init 2 2 gridCell
 ||> Err error -> Err error
 ||> Ok matrix -> Ok (reduce add 0 matrix)

value sameCount : Bool = chosenCount == 2
