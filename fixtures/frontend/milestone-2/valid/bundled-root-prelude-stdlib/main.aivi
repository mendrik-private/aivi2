use aivi (
    Ordering
    Option
    Result
    Validation
    Signal
    Task
    Less
    Equal
    Greater
    Some
    None
    Ok
    Err
    Valid
    Invalid
)

use aivi.prelude (
    Int
    Bool
    Text
    List
    Eq
    Default
    Functor
    Ord
    Semigroup
    Monoid
    Bifunctor
    Traversable
    Filterable
    Applicative
    Monad
    Foldable
    getOrElse
    withDefault
    length
    head
    min
    max
    minOf
    join
)

type NameSignal = Signal Text

type CountTask = Task Text Int

type CheckedName =
  | Validation Text Text

val maybeName: Option Text = Some "Ada"
val missingName: Option Text = None
val chosenName: Text = getOrElse "guest" missingName
val okCount: Result Text Int = Ok 2
val errCount: Result Text Int = Err "missing"
val chosenCount: Int = withDefault 0 okCount
val checkedName: CheckedName = Valid "Ada"

val nameCount: Int =
    length [
        "Ada",
        "Grace"
    ]

val firstName: Option Text =
    head [
        "Ada",
        "Grace"
    ]

fun smaller:Bool #left:Int #right:Int =>
    left < right

fun keepSmall:(Option Int) #value:Int =>
    value < 3
     T|> Some value
     F|> None

fun addOne:Int #value:Int =>
    value + 1

fun punctuate:Text #value:Text =>
    append value "!"

val leastCount: Int = min smaller 4 2
val greatestCount: Int = max smaller 4 2
val explicitLess: Ordering = Less

val leastOfCounts: Int =
    minOf smaller 5 [
        3,
        4
    ]

val labels: Text =
    join ", " [
        "Ada",
        "Grace"
    ]

val orderedCount: Ordering = compare 1 2
val combinedLabel: Text = append "Ada" " Lovelace"
val emptyLabels: Text = empty
val mappedOk: Result Text Int = bimap punctuate addOne (Ok 1)

val traversedCounts: Option (List Int) =
    traverse keepSmall [
        1,
        2
    ]

val filteredCounts: List Int =
    filterMap keepSmall [
        1,
        3,
        2
    ]

val sameCount: Bool = chosenCount == 2
