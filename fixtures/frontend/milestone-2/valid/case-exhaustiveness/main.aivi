type Screen =
  | Loading
  | Ready Text
  | Failed Text

value current : Screen = Loading

type Bool -> Text
func boolLabel = ready=> ready ||> True  -> "ready"
 ||> False -> "waiting"

type (Option Text) -> Text
func maybeLabel = maybeUser=> maybeUser ||> Some name -> name
 ||> None      -> "login"

type (Result Text Text) -> Text
func resultLabel = status=> status ||> Ok body     -> body
 ||> Err message -> message

type (Validation Text Text) -> Text
func validationLabel = status=> status ||> Valid body      -> body
 ||> Invalid message -> message

type Screen -> Text
func screenLabel = screen=> screen ||> Loading       -> "loading"
 ||> Ready title   -> title
 ||> Failed reason -> reason

type Text -> Text
func titleLabel = title=> title == "Inbox" T|> "priority"
 F|> title

type Screen -> Text
func nestedScreenLabel = screen=> screen ||> Loading       -> "loading"
 ||> Ready title   -> titleLabel title
 ||> Failed reason -> reason

value screenView =
    <with value={current} as={screen}>
        <match on={screen}>
            <case pattern={Loading}>
                <Label text="Loading..." />
            </case>
            <case pattern={Ready title}>
                <Label text={title} />
            </case>
            <case pattern={Failed reason}>
                <Label text={reason} />
            </case>
        </match>
    </with>
