type UserDraft = UserDraft Text Text Int
type NamePair = NamePair Text Text

value defaultAge = 36

signal nameText = "Ada"
signal emailText = "ada@example.com"
signal ageValue = defaultAge
signal firstName = "Ada"
signal lastName = "Lovelace"

signal validatedUser =
 &|> nameText
 &|> emailText
 &|> ageValue
  |> UserDraft

signal namePair =
 &|> firstName
 &|> lastName
  |> NamePair
