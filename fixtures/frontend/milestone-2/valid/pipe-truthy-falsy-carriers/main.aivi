type User = { name: Text }

type LoadError = {
    message: Text
}

type FormError = {
    message: Text
}

value ready: Bool = True
value start: Text = "start"
value wait: Text = "wait"

value readyText: Text =
    ready
     T|> start
     F|> wait

value maybeUser: Option User =
    Some {
        name: "Ada"
    }

value greeting: Text =
    maybeUser
     T|> .name
     F|> "guest"

value maybeDisplay: Option Text =
    maybeUser
     F|> "guest"
     T|> .name
     ?|> True

value loaded: Result LoadError User =
    Err {
        message: "offline"
    }

value rendered: Text =
    loaded
     T|> .name
     F|> .message

value nestedRendered: Text =
    ready
     T|> (loaded ||> Ok user => user.name ||> Err loadFail => loadFail.message)
     F|> wait

value submitted: Validation FormError User =
    Valid {
        name: "Grace"
    }

value summary: Text =
    submitted
     T|> .name
     F|> .message
