use aivi.list (
    any
    findMap
    length
)

use aivi.text (join)

type Symbol = Zero | One

type NfaState =
  | Start
  | BranchA
  | BranchB
  | Accept

type Edge = {
    from: NfaState,
    symbol: Symbol,
    to: List NfaState
}

type DfaSummary = {
    label: Text,
    count: Int,
    accepting: Bool
}

type NfaCatalog = {
    start: DfaSummary,
    onZero: DfaSummary,
    onOneAfterZero: DfaSummary,
    missingOnZero: DfaSummary
}

value isState:Bool expected:NfaState candidate:NfaState =>
    candidate == expected

value stateName:Text state:NfaState =>
    state
     ||> Start   => "start"
     ||> BranchA => "branch-a"
     ||> BranchB => "branch-b"
     ||> Accept  => "accept"

value collectNames:(List Text) labels:(List Text) state:NfaState =>
    append labels [
        stateName state
    ]

value subsetLabel:Text subset:(List NfaState) =>
    length subset == 0
     T|> "empty"
     F|> join "," (subset |> reduce collectNames [])

value containsState:Bool candidate:NfaState subset:(List NfaState) =>
    subset
     |> any (isState candidate)

value insertState:(List NfaState) subset:(List NfaState) state:NfaState =>
    containsState state subset
     T|> subset
     F|> append subset [state]

value transitions: List Edge = [
    {
        from: Start,
        symbol: Zero,
        to: [BranchA, BranchB]
    },
    {
        from: BranchA,
        symbol: One,
        to: [Accept]
    },
    {
        from: BranchB,
        symbol: Zero,
        to: [BranchB]
    },
    {
        from: BranchB,
        symbol: One,
        to: [Accept]
    }
]

value matchingTargets:(Option (List NfaState)) from:NfaState symbol:Symbol edge:Edge =>
    (edge.from == from) and (edge.symbol == symbol)
     T|> Some edge.to
     F|> None

value moveFromState:(List NfaState) from:NfaState symbol:Symbol =>
    transitions
     |> findMap (matchingTargets from symbol)
     ||> Some targets => targets
     ||> None         => []

value moveStep:(List NfaState) symbol:Symbol subset:(List NfaState) state:NfaState =>
    moveFromState state symbol
     |> reduce insertState subset

value moveSet:(List NfaState) subset:(List NfaState) symbol:Symbol =>
    subset
     |> reduce (moveStep symbol) []

value acceptingSubset:Bool subset:(List NfaState) =>
    subset
     |> any (isState Accept)

value summarize:DfaSummary subset:(List NfaState) =>
    {
        label: subsetLabel subset,
        count: length subset,
        accepting: acceptingSubset subset
    }

value startSubset: List NfaState = [
    Start
]

value zeroSubset: List NfaState = moveSet startSubset Zero
value oneAfterZeroSubset: List NfaState = moveSet zeroSubset One
value missingOnZeroSubset: List NfaState = moveSet oneAfterZeroSubset Zero

value nfaCatalog: NfaCatalog = {
    start: summarize startSubset,
    onZero: summarize zeroSubset,
    onOneAfterZero: summarize oneAfterZeroSubset,
    missingOnZero: summarize missingOnZeroSubset
}

export nfaCatalog
