use aivi.list (
    any
    tail
)

use aivi.option (getOrElse)

type Node =
  | Source
  | Mid
  | Detour
  | Goal
  | Stranded

type WeightedEdge = {
    from: Node,
    to: Node,
    weight: Int
}

type WeightedGraph = {
    nodes: List Node,
    edges: List WeightedEdge,
    source: Node
}

type Distance =
  | Unreachable
  | Cost Int

type Distances = {
    source: Distance,
    mid: Distance,
    detour: Distance,
    goal: Distance,
    stranded: Distance
}

type BellmanFordCatalog = {
    stableGoal: Text,
    stableDetour: Text,
    stableStranded: Text,
    negativeCycleDetected: Bool,
    negativeWitness: Text
}

value emptyDistances: Distances = {
    source: Unreachable,
    mid: Unreachable,
    detour: Unreachable,
    goal: Unreachable,
    stranded: Unreachable
}

value negativeWeightEdge: WeightedEdge = {
    from: Mid,
    to: Detour,
    weight: 0 - 2
}

value negativeCycleWitness: Text = "mid -> detour -> mid"

fun chooseNode: A node:Node source:A mid:A detour:A goal:A stranded:A =>
    node
     ||> Source   -> source
     ||> Mid      -> mid
     ||> Detour   -> detour
     ||> Goal     -> goal
     ||> Stranded -> stranded

fun distanceText: Text distance:Distance =>
    distance
     ||> Unreachable -> "unreachable"
     ||> Cost x      -> "{x}"

fun distanceOf: Distance distances:Distances node:Node =>
    chooseNode node distances.source distances.mid distances.detour distances.goal distances.stranded

fun setDistance: Distances distances:Distances node:Node x:Distance =>
    node
     ||> Source   -> { source: x, mid: distances.mid, detour: distances.detour, goal: distances.goal, stranded: distances.stranded }
     ||> Mid      -> { source: distances.source, mid: x, detour: distances.detour, goal: distances.goal, stranded: distances.stranded }
     ||> Detour   -> { source: distances.source, mid: distances.mid, detour: x, goal: distances.goal, stranded: distances.stranded }
     ||> Goal     -> { source: distances.source, mid: distances.mid, detour: distances.detour, goal: x, stranded: distances.stranded }
     ||> Stranded -> { source: distances.source, mid: distances.mid, detour: distances.detour, goal: distances.goal, stranded: x }

fun betterDistance: Bool left:Distance right:Distance =>
    (left, right)
     ||> (Cost _, Unreachable) -> True
     ||> (Cost l, Cost r)      -> l < r
     ||> (Unreachable, _)      -> False

fun plusDistance: Distance distance:Distance weight:Int =>
    distance
     ||> Cost x      -> Cost (x + weight)
     ||> Unreachable -> Unreachable

fun candidateDistance: Distance distances:Distances edge:WeightedEdge =>
    plusDistance (distanceOf distances edge.from) edge.weight

fun preferDistance: Distance current:Distance candidate:Distance =>
    betterDistance candidate current
     T|> candidate
     F|> current

fun relaxTarget: Distances distances:Distances target:Node candidate:Distance =>
    setDistance distances target (preferDistance (distanceOf distances target) candidate)

fun relaxEdge: Distances distances:Distances edge:WeightedEdge =>
    relaxTarget distances edge.to (candidateDistance distances edge)

fun runPass: Distances graph:WeightedGraph distances:Distances tick:Node =>
    graph.edges
     |> reduce relaxEdge distances

fun passSchedule: (List Node) graph:WeightedGraph =>
    graph.nodes
     |> tail
     |> getOrElse []

fun edgeCanRelax: Bool distances:Distances edge:WeightedEdge =>
    betterDistance (candidateDistance distances edge) (distanceOf distances edge.to)

fun cycleWitness: Text detected:Bool =>
    detected
     T|> negativeCycleWitness
     F|> "none"

fun initialDistances: Distances graph:WeightedGraph =>
    setDistance emptyDistances graph.source (Cost 0)

value stableGraph: WeightedGraph = {
    nodes: [
        Source,
        Mid,
        Detour,
        Goal,
        Stranded
    ],
    source: Source,
    edges: [
        {
            from: Source,
            to: Mid,
            weight: 4
        },
        {
            from: Source,
            to: Detour,
            weight: 5
        },
        negativeWeightEdge,
        {
            from: Detour,
            to: Goal,
            weight: 3
        }
    ]
}

value negativeCycleGraph: WeightedGraph = {
    nodes: [Source, Mid, Detour, Goal],
    source: Source,
    edges: [
        {
            from: Source,
            to: Mid,
            weight: 1
        },
        {
            from: Mid,
            to: Detour,
            weight: 0 - 2
        },
        {
            from: Detour,
            to: Mid,
            weight: 0 - 2
        },
        {
            from: Detour,
            to: Goal,
            weight: 1
        }
    ]
}

value stableDistances: Distances =
    passSchedule stableGraph
     |> reduce (runPass stableGraph) (initialDistances stableGraph)

value negativeCycleDistances: Distances =
    passSchedule negativeCycleGraph
     |> reduce (runPass negativeCycleGraph) (initialDistances negativeCycleGraph)

value negativeCycleDetected: Bool =
    negativeCycleGraph.edges
     |> any (edgeCanRelax negativeCycleDistances)

value bellmanFordCatalog: BellmanFordCatalog = {
    stableGoal: distanceText (distanceOf stableDistances Goal),
    stableDetour: distanceText (distanceOf stableDistances Detour),
    stableStranded: distanceText (distanceOf stableDistances Stranded),
    negativeCycleDetected,
    negativeWitness: cycleWitness negativeCycleDetected
}

export bellmanFordCatalog
