<component type="desktop-application">
  <id>org.aivi.Aivi</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>AIVI</name>
  <summary>Purely functional GTK4/libadwaita language and runtime</summary>

  <description>
    <p>
      AIVI is a purely functional, reactive programming language designed
      specifically for building GTK4 and libadwaita desktop applications on Linux.
      It compiles to native code via Cranelift and provides a hot-reloadable
      development experience.
    </p>
    <p>Features:</p>
    <ul>
      <li>Purely functional reactive signals model</li>
      <li>First-class GTK4/libadwaita widget markup</li>
      <li>Native code generation via Cranelift</li>
      <li>Hot-reloadable development workflow</li>
      <li>Language server with diagnostics, completions, and navigation</li>
    </ul>
  </description>

  <launchable type="desktop-id">org.aivi.Aivi.desktop</launchable>

  <screenshots>
