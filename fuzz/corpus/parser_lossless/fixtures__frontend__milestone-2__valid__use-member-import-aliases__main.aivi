use aivi.network (
    http as primaryHttp
    socket as fallbackSocket
    Request as HttpRequest
    Channel as NetworkChannel
)

type PrimaryRequest = (HttpRequest Text)

type ProviderChannel = (NetworkChannel Text Text)

type Text -> Text -> Text
func joinProviders = left right =>
    "{left}/{right}"

value primaryProvider = primaryHttp
value fallbackProvider = fallbackSocket
value providerPair = joinProviders primaryProvider fallbackProvider
