type User = {
    name: Text,
    email: Text
}

type User -> Text
func formatUser = user => user
 ||> { name, email } -> "{name} <{email}>"

value user : User = {
    name: "Ada",
    email: "ada@example.com"
}

value userCard =
    <show when={True} keepMounted={True}>
        <fragment>
            <with value={formatUser user} as={label}>
                <Label text={label} />
            </with>
            <Label text="{user.email}" />
        </fragment>
    </show>
