type User = User Text Int

type LoadState =
  | NotAsked
  | Loaded User
  | Failed Text

fun loadedName:Text = #state:LoadState=>    state
     ||> NotAsked => "waiting"
     ||> Loaded (User name _) => name
     ||> Failed message => message

fun firstOfPair:Int = #pair:(Int, Int)=>    pair
     ||> (first, _) => first
