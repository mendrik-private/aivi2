type HttpError =
  | Timeout
  | BadStatus Int

type Profile = {
    nickname: Option Text,
    login: Result HttpError Text,
    queued: Validation Text Int,
    watching: Signal Bool,
    background: Task HttpError Int,
    headers: Map Text Text,
    tags: Set Text
}

type HttpResult A = (Result HttpError A)
type LoadedProfile = (HttpResult Profile)
type HeaderMap = (Map Text Text)
type TagSet = (Set Text)
type PendingProfiles = (Task HttpError (Map Text Profile))

domain ResourceId A over A
    type A -> ResourceId A
    wrap
    type ResourceId A -> A
    unwrap

domain HeaderBag over Map Text Text
    type Text -> HeaderBag -> Option Text
    lookup

domain Tags over Set Text
    type Text -> Tags -> Bool
    contains

type ResourceText = (ResourceId Text)

fun keepHeaders:Map Text Text = #headers:Map Text Text=>    headers

fun keepTags:Set Text = #tags:Set Text=>    tags

val defaultNickname : Option Text = None
