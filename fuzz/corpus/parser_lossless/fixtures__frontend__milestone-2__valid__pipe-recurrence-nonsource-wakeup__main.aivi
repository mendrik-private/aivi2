domain Duration over Int
    literal sec : Int -> Duration

domain Retry over Int
    literal rt : Int -> Retry

fun step #value =>
    value

@recur.timer 5sec
sig polled : Signal Int =
    0
     @|> step
     <|@ step

@recur.backoff 3rt
val retried : Task Int Int =
    0
     @|> step
     <|@ step
