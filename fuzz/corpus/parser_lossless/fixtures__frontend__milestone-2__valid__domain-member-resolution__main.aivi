domain Duration over Int = {
    literal ms : Int -> Duration
    type Int -> Duration
    make
    type Duration -> Int
    unwrap
}

domain Count over Int = {
    type Int -> Count
    make
}

domain NonEmpty A over List A = {
    type A -> NonEmpty A
    singleton
    type NonEmpty A -> A
    head
}

value delay : Duration = make 250
value delayMillis : Int = unwrap delay
value literalMillis : Int = unwrap 250ms
value first : Int = head (singleton 1)

export first
