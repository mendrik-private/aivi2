use aivi.defaults (Option)

use aivi.nonEmpty (
    NonEmptyList
    singleton
    head as nelHead
    toList as nelToList
    cons as nelCons
)

use aivi.validation (
    Errors
    isValid
    isInvalid
    getOrElse as validationGetOrElse
    toResult as validationToResult
    toOption as validationToOption
    mapErr as validationMapErr
)

use aivi.list (
    isEmpty
    nonEmpty
    length
    head
    tail
    last
    find
    partition
    Partition
)

use aivi.order (
    min
    max
    minOf
)

use aivi.option (
    isSome
    isNone
    getOrElse
    toResult
    toList as optionToList
)

use aivi.result (
    isOk
    isErr
    withDefault
    mapErr
    toOption
)

use aivi.text (
    join
    surround
    isEmpty as textIsEmpty
    nonEmpty as textNonEmpty
)

use aivi.duration (
    Duration
    DurationError
)

use aivi.url (
    Url
    UrlError
)

use aivi.path (
    Path
    PathError
)

use aivi.color (Color)

type LeadingName =
  NonEmptyList Text

type User = {
    name: Text,
    nickname: Option Text,
    email: Option Text
}

value user : User = {
    name: "Ada"
}

value ok : Validation (NonEmptyList Text) Text = Valid "Ada"
value err : Validation (NonEmptyList Text) Text = Invalid (singleton "field required")
value isOkSentinel : Bool = isValid ok
value isErrSentinel : Bool = isInvalid err
value names : NonEmptyList Text = singleton "Ada"
value nameHead : Text = nelHead names
value nameList : List Text = nelToList names
value longerNames : NonEmptyList Text = nelCons "Grace" names
value errors : NonEmptyList Text = singleton "field required"

value numbers : List Int = [
    1,
    2,
    3
]

value emptyList : List Int = []
value numsEmpty : Bool = isEmpty emptyList
value numsPresent : Bool = nonEmpty numbers
value numsLength : Int = length numbers
value numsHead : Option Int = head numbers
value numsTail : Option (List Int) = tail numbers
value numsLast : Option Int = last numbers

type Int -> Int -> Bool
func smaller = left right =>
    left < right

value smallestNumber : Int = min smaller 4 2
value largestNumber : Int = max smaller 4 2

value smallestFromMany : Int =
    minOf smaller 6 [
        4,
        9,
        2
    ]

type Int -> Bool
func positive = n =>
    n > 0

value foundPositive : Option Int = find positive numbers

type Int -> Bool
func even = n =>
    n == 2

value split : (Partition Int) = partition even numbers

value greeting : Text =
    join ", " [
        "Hello",
        "World"
    ]

value combined : Text =
    join "" [
        "a",
        "i",
        "v",
        "i"
    ]

value wrapped : Text = surround "[" "]" greeting
value emptyStr : Bool = textIsEmpty ""
value nonEmptyStr : Bool = textNonEmpty "aivi"
value maybeId : Option Int = Some 42
value hasId : Bool = isSome maybeId
value noId : Option Int = None
value missingId : Bool = isNone noId
value idValue : Int = getOrElse 0 maybeId
value idItems : List Int = optionToList maybeId
value idResult : Result Text Int = toResult "no-id" maybeId
value okAge : Result Text Int = Ok 30
value errAge : Result Text Int = Err "missing"
value ageOk : Bool = isOk okAge
value ageErr : Bool = isErr errAge
value ageValue : Int = withDefault 0 okAge
value ageOption : Option Int = toOption okAge

type Text -> Text
func prefixErr = msg =>
    "error:{msg}"

value prefixedErr : Result Text Int = mapErr prefixErr errAge

type PollDelay = Duration

type ServiceUrl = Url

type DataPath = Path

type ThemeColor = Color
