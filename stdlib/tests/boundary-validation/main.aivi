type User = { id: Int }

value headers : HttpHeaders =
    Map {
        "Authorization": "Bearer demo"
    }

value query : HttpQuery =
    Map {
        "page": "1"
    }

value decodeMode : DecodeMode = Strict

type RetryBudget = Retry

type UsersResponse = (HttpResponse (List User))

type UsersTask = (Task Text (List User))

@source http "https://api.example.com"
signal api : HttpSource

signal users : Signal UsersResponse = api.get "/users"

@source timer.every 120 with {
    immediate: True
}
signal tick : Signal TimerTick

@source timer.after 1000
signal ready : Signal TimerReady

value timeoutError : HttpError = Timeout
value decodeError : HttpError = DecodeFailure "bad-json"
value requestError : HttpError = RequestFailure "offline"
value level : LogLevel = Debug

value context : LogContext =
    Map {
        "module": "stdlib"
    }

value entry : LogEntry = {
    level: level,
    message: "loaded",
    context: context
}

type Writer = LogSink

type CurrentLogTask = (Task LogError Unit)

type CurrentLogError = LogError

type PollDelay = Duration

value errorLevel : LogLevel = Error
value fsCreated : FsEvent = Created
value fsChanged : FsEvent = Changed
value fsDeleted : FsEvent = Deleted
value fsNotFound : FsError = NotFound "/etc/missing"
value fsPermDenied : FsError = PermissionDenied "/root/file"
value pkceUserCancelled : PkceError = UserCancelled
value pkceTimedOut : PkceError = PkceTimeout
value busOwned : BusNameState = Owned
value busQueued : BusNameState = Queued
value busLost : BusNameState = Lost
value dbusNoReply : DbusError = NoReply

value testCall : DbusCall = {
    destination: "org.gnome.AiviMail.Daemon",
    path: "/org/gnome/AiviMail/Daemon",
    interface: "org.gnome.AiviMail.IDaemon",
    member: "TriggerSync",
    body: []
}

value testSignal : DbusSignal = {
    path: "/org/gnome/AiviMail/Daemon",
    interface: "org.gnome.AiviMail.IDaemon",
    member: "SyncStateChanged",
    body: []
}

type MailCapability = GoaCapability

value mailCap : GoaCapability = Mail

value notification : Notification = {
    summary: "New mail",
    body: Some "You have 3 new messages",
    icon: Some "mail-unread",
    actions: []
}

value notifFailed : NotificationError = NotificationFailed "dbus error"
value schemaMismatch : DbError = SchemaMismatch "v2 required"
value queryFailed : DbError = QueryFailed "no such table"
value constraintViolation : DbError = ConstraintViolation "unique users_email"
value nestedTransaction : DbError = NestedTransaction
value connectionFailed : DbError = ConnectionFailed "offline"
value sortAsc : SortDir = Asc
value sortDesc : SortDir = Desc

signal usersChanged : Signal Unit

value connection : Connection = {
    database: "/tmp/aivi-demo.db"
}

value userTable : TableRef User = {
    name: "users",
    conn: connection,
    changed: usersChanged
}

signal dbEnabled = True

value pageOpts : DbPageOpts = {
    limit: 25,
    offset: 0
}

value userIdParam : DbParam = {
    kind: "int",
    bool: None,
    int: Some 7,
    float: None,
    decimal: None,
    bigInt: None,
    text: None,
    bytes: None
}

value userQuery : DbStatement = {
    sql: "select * from users where id = ?",
    arguments: [userIdParam]
}

value liveUsersQuery : Task Text (List DbRow) = pure []

@source db.connect connection with {
    pool: 2,
    activeWhen: dbEnabled
}
signal liveConnection : Signal (Result DbError Connection)

@source db.live liveUsersQuery with {
    refreshOn: usersChanged,
    activeWhen: dbEnabled
}
signal liveUsers : Signal (Result DbError (List DbRow))

value syncState : SyncState = {
    lastSyncedAt: None,
    inProgress: True,
    error: None
}

value imapAuthFailed : ImapError = ImapAuthFailed
value imapConnFailed : ImapError = ImapConnectionFailed "timeout"

value smtpConfig : SmtpConfig = {
    host: "smtp.gmail.com",
    port: 587
}

value smtpAuthFailed : SmtpError = SmtpAuthFailed

@source fs "."
signal workspaceFiles : FsSource

@source fs "/tmp"
signal tempFiles : FsSource

@source stdio
signal console : StdioSource

@source process
signal runtime : ProcessSource

@source env
signal hostEnv : EnvSource

@source path
signal systemPaths : PathSource

@source log
signal logger : LogSource

@source random
signal entropy : RandomSource

value healthCheck : Task Text Text = api.get "/health"

signal cargoToml : Signal (Result FsError Text) = workspaceFiles.read "Cargo.toml"

value fsExistsTask : Task Text Bool = workspaceFiles.exists "Cargo.toml"
value stdoutTask : Task Text Unit = console.stdoutWrite "stdout"
value stderrTask : Task Text Unit = console.stderrWrite "stderr"
value mkdirTask : Task Text Unit = tempFiles.createDirAll "aivi-boundary"
value writeTextTask : Task Text Unit = tempFiles.writeText "aivi-boundary/out.txt" "ok"
value deleteTask : Task Text Unit = tempFiles.deleteFile "aivi-boundary/out.txt"
value logTask : Task LogError Unit = logger.emit levelInfo "loaded"
value randomIntTask : Task Text Int = entropy.int 1 10
value envListTask : Task Text (List (Text, Text)) = hostEnv.list ""

signal cliArgs : Signal (List Text) = runtime.args
signal cliCwd : Signal Text = runtime.cwd
signal cliToken : Signal (Option Text) = hostEnv.get "ACCESS_TOKEN"
signal stdinText : Signal Text = console.read
signal homeDir : Signal Text = systemPaths.home
signal configHomeDir : Signal Text = systemPaths.configHome
signal dataHomeDir : Signal Text = systemPaths.dataHome
signal cacheHomeDir : Signal Text = systemPaths.cacheHome
signal tempDir : Signal Text = systemPaths.tempDir
