type NotificationAction = {
    label: Text,
    id: Text
}

type Notification = {
    summary: Text,
    body: Option Text,
    icon: Option Text,
    actions: List NotificationAction
}

type NotificationError =
  | NotificationFailed Text

type NotificationResponse =
  | ActionTriggered Text
  | Dismissed

export (NotificationAction, Notification, NotificationError, NotificationFailed, NotificationResponse, ActionTriggered, Dismissed)
