use aivi.nonEmpty (NonEmptyList)

type Errors E = NonEmptyList E

fun isValid:Bool value:(Validation E A) =>
    value
     T|> True
     F|> False

fun isInvalid:Bool value:(Validation E A) =>
    value
     F|> True
     T|> False

fun getOrElse:A fallback:A value:(Validation E A) =>
    value
     ||> Valid item => item
     ||> Invalid _  => fallback

fun mapErr:(Validation E2 A) transform:(E1 -> E2) value:(Validation E1 A) =>
    value
     ||> Valid item  => Valid item
     ||> Invalid err => Invalid (transform err)

fun toResult:(Result E A) value:(Validation E A) =>
    value
     ||> Valid item  => Ok item
     ||> Invalid err => Err err

fun fromResult:(Validation E A) value:(Result E A) =>
    value
     ||> Ok item   => Valid item
     ||> Err error => Invalid error

fun toOption:(Option A) value:(Validation E A) =>
    value
     T|> Some
     F|> None

export Errors
export isValid
export isInvalid
export getOrElse
export mapErr
export toResult
export fromResult
export toOption
