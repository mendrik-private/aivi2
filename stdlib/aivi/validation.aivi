use aivi.nonEmpty (NonEmptyList)

type Errors E = NonEmptyList E

fun isValid:Bool opt:(Validation E A) =>
    opt
     T|> True
     F|> False

fun isInvalid:Bool opt:(Validation E A) =>
    opt
     F|> True
     T|> False

fun getOrElse:A fallback:A opt:(Validation E A) =>
    opt
     ||> Valid item -> item
     ||> Invalid _  -> fallback

fun mapErr:(Validation E2 A) transform:(E1 -> E2) opt:(Validation E1 A) =>
    opt
     ||> Valid item  -> Valid item
     ||> Invalid err -> Invalid (transform err)

fun toResult:(Result E A) opt:(Validation E A) =>
    opt
     ||> Valid item  -> Ok item
     ||> Invalid err -> Err err

fun fromResult:(Validation E A) opt:(Result E A) =>
    opt
     ||> Ok item   -> Valid item
     ||> Err error -> Invalid error

fun toOption:(Option A) opt:(Validation E A) =>
    opt
     T|> Some
     F|> None

export Errors
export isValid
export isInvalid
export getOrElse
export mapErr
export toResult
export fromResult
export toOption
