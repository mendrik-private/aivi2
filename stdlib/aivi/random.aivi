type RandomError =
  | InsufficientEntropy

type RandomSource = Unit

type RandomTask = (Task Text Bytes)

type RandomIntTask = (Task Text Int)

type RandomBytesTask = (Task Text Bytes)

type RandomFloatTask = (Task Text Float)

export (RandomError, InsufficientEntropy, RandomSource, RandomTask, RandomIntTask, RandomBytesTask, RandomFloatTask)
