use aivi.arithmetic (
    add
    sub
    mul
    div
    mod
    neg
)

type Int -> Int -> Int
func intAdd = a b =>
    add a b

type Int -> Int -> Int
func intSub = a b =>
    sub a b

type Int -> Int -> Int
func intMul = a b =>
    mul a b

type Int -> Int -> Int
func intDiv = a b =>
    div a b

type Int -> Int -> Int
func intMod = a b =>
    mod a b

type Int -> Int
func intNeg = a =>
    neg a

export (intAdd, intSub, intMul, intDiv, intMod, intNeg)
