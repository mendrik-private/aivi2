type FsError =
  | NotFound Text
  | PermissionDenied Text
  | ReadFailed Text
  | WriteFailed Text
  | FsProtocolError Text

type FsEvent =
  | Created
  | Changed
  | Deleted

type FsReadTask = (Task FsError Text)

type FsWriteTask = (Task FsError Unit)

export (FsError, NotFound, PermissionDenied, ReadFailed, WriteFailed, FsProtocolError, FsEvent, Created, Changed, Deleted, FsReadTask, FsWriteTask)
