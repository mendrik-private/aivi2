type UrlError = Text

domain Url over Text = {
    type Text -> Result UrlError Url
    parse
    type Url -> Text
    unwrap
    type Url -> Option Text
    scheme
    type Url -> Option Text
    host
    type Url -> Option Int
    port
    type Url -> Text
    path
    type Url -> Option Text
    query
    type Url -> Option Text
    fragment
    type Url -> Text -> Url
    withPath
    type Url -> Text -> Url
    withQuery
}

export UrlError
export Url
