use aivi.core.dict (Dict)

type JsonError =
  | InvalidJson Text
  | MissingKey Text
  | IndexOutOfBounds Int
  | WrongType Text

type Json =
  | JsonNull
  | JsonBool Bool
  | JsonNumber Float
  | JsonString Text
  | JsonArray (List Json)
  | JsonObject (Dict Text Json)

type JsonPath = (List Text)

export (JsonError, InvalidJson, MissingKey, IndexOutOfBounds, WrongType, Json, JsonNull, JsonBool, JsonNumber, JsonString, JsonArray, JsonObject, JsonPath)
