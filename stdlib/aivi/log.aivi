use aivi.core.dict (Dict)

type LogLevel =
  | Debug
  | Info
  | Warn
  | Error

type LogContext = (Dict Text Text)

type LogEntry = {
    level: LogLevel
}

type LogError = Text

type LogTask = (Task LogError Unit)

type LogSink = (LogEntry -> LogTask)

export (LogLevel, Debug, Info, Warn, Error, LogContext, LogEntry, LogError, LogTask, LogSink)
