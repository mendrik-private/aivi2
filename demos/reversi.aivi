]

value initial : GameState = {
    board: initialBoard,
    status: Active Human,
    legalMoves: [
        Coord 3 2,
        Coord 2 3,
        Coord 5 4,
        Coord 4 5
    ],
    humanCount: 2,
    computerCount: 2,
    moveNumber: 0,
    lastMove: None,
    lastFlips: [],
    animState: Idle
}

value noFlips : List Coord = []
value previewBlinkCycleTicks = 9
value previewBlinkVisibleTicks = 5
value previewLastTick = 25
value placedFlashCycle = 5
value placedFlashVisible = 3
value placedFlashDuration = 15
value flippedFlashCycle = 2
value flippedFlashVisible = 1
value flippedFlashDuration = 10
value flashDuration = 15

type Int -> Bool
func oneFromEdge = n =>
    n == 1 or n == lastIndex - 1

type Int -> Bool
func twoFromEdge = n =>
    n == 2 or n == lastIndex - 2

type Coord -> Bool
func cornerCoord = coord =>
    coordInList coord corners

type Coord -> Bool
func cornerBand = .
 ||> Coord x y -> (x <= 1 or x >= lastIndex - 1) and (y <= 1 or y >= lastIndex - 1)

type Coord -> Bool
func edgeCoord = .
 ||> Coord x y -> x == 0 or x == lastIndex or y == 0 or y == lastIndex

type Coord -> Bool
func innerRing = .
 ||> Coord x y -> oneFromEdge x or oneFromEdge y

type Coord -> Bool
func secondRing = .
 ||> Coord x y -> twoFromEdge x or twoFromEdge y

type Coord -> Int
func positionalWeight = coord => (cornerCoord coord, cornerBand coord, edgeCoord coord, innerRing coord, secondRing coord)
 ||> (True, _, _, _, _)                 -> 160
 ||> (False, True, _, _, _)             -> -60
 ||> (False, False, True, _, _)         -> 18
 ||> (False, False, False, True, _)     -> -4
 ||> (False, False, False, False, True) -> 8
 ||> _                                  -> 3

type Coord -> Int
func finalCandidateScore = coord =>
    positionalWeight coord * 12

type Coord -> Candidate
func buildCandidate = coord =>
    {
        coord: coord,
        flips: 0,
        score: finalCandidateScore coord
    }

type List (List Disc) -> Coord -> Candidate
func candidateForCoord = board coord =>
    buildCandidate coord

type Candidate -> Candidate -> Bool
func betterCandidate = left right =>
    left.score < right.score or (left.score == right.score and left.flips < right.flips) or (left.score == right.score and left.flips == right.flips and coordId left.coord > coordId right.coord)

type List (List Disc) -> (List Coord) -> (Option Candidate)
func bestComputerMove = board moves => moves
  |> listMap (candidateForCoord board)
  |> listMaximum betterCandidate

type Turn -> GameState -> Int -> Int
func nextHumanCount = turn state flipCount => turn
 ||> Human    -> state.humanCount + flipCount + 1
 ||> Computer -> state.humanCount - flipCount

type Turn -> GameState -> Int -> Int
func nextComputerCount = turn state flipCount => turn
 ||> Human    -> state.computerCount - flipCount
 ||> Computer -> state.computerCount + flipCount + 1

type GameState -> Turn -> Coord -> Int -> (List Coord) -> (List (List Disc)) -> GameState
func applyResolvedBoard = state turn coord flipCount flips afterBoard =>
    makeState afterBoard (state.moveNumber + 1) (Some coord) flips (nextHumanCount turn state flipCount) (nextComputerCount turn state flipCount) (advanceTurn afterBoard (otherTurn turn))

type GameState -> Turn -> Coord -> (List Coord) -> GameState
func applyResolvedTurn = state turn coord flips => boardAfterFlips state.board (discForTurn turn) coord flips
  |> applyResolvedBoard state turn coord (listLength flips) flips

type GameState -> Turn -> Coord -> GameState
func applyTurnMove = state turn coord => flipsForMove state.board (discForTurn turn) coord
  |> applyResolvedTurn state turn coord

type Coord -> GameState -> GameState
func handleTryPlace = coord state => (humanToAct state.status, coordInList coord state.legalMoves)
 ||> (True, True) -> applyHumanMove state coord
 ||> _            -> state

type GameState -> AnimState -> GameState
func setAnimState = state animState =>
    {
        board: state.board,
        status: state.status,
        legalMoves: state.legalMoves,
        humanCount: state.humanCount,
        computerCount: state.computerCount,
        moveNumber: state.moveNumber,
        lastMove: state.lastMove,
        lastFlips: state.lastFlips,
        animState: animState
    }

type GameState -> Coord -> (List Coord) -> GameState
func applyHumanMoveWithFlips = state coord flips =>
    {
        board: boardAfterFlips state.board (discForTurn Human) coord flips,
        status: Active Computer,
        legalMoves: [],
        humanCount: state.humanCount + listLength flips + 1,
        computerCount: state.computerCount - listLength flips,
        moveNumber: state.moveNumber + 1,
        lastMove: Some coord,
        lastFlips: flips,
        animState: HumanFlash coord flips 0
    }

type GameState -> Coord -> GameState
func applyHumanMove = state coord => flipsForMove state.board (discForTurn Human) coord
  |> applyHumanMoveWithFlips state coord

type GameState -> (List (List Disc)) -> AnimState -> GameState
func computerAnimState = state board animState =>
    {
        board: board,
        status: Active Computer,
        legalMoves: [],
        humanCount: countDisc Red board,
        computerCount: countDisc Blue board,
        moveNumber: state.moveNumber,
        lastMove: state.lastMove,
        lastFlips: state.lastFlips,
        animState: animState
    }

type GameState -> Coord -> (List Coord) -> GameState
func beginComputerPreview = state coord flips =>
    computerAnimState state state.board (Previewing coord flips 0)

type GameState -> Coord -> (List Coord) -> GameState
func beginComputerFlips = state coord flips =>
    computerAnimState state (put coord (discForTurn Computer) state.board) (Flipping coord flips flips)

type GameState -> Coord -> (List Coord) -> Int -> GameState
func advanceComputerPreview = state coord flips tick => tick >= previewLastTick
 T|> beginComputerFlips state coord flips
 F|> computerAnimState state state.board (Previewing coord flips (tick + 1))

type GameState -> Coord -> (List Coord) -> GameState
func finishComputerAnimation = state coord flips =>
    makeState state.board (state.moveNumber + 1) (Some coord) flips (countDisc Red state.board) (countDisc Blue state.board) (advanceTurn state.board Human)

type GameState -> Coord -> (List Coord) -> (List Coord) -> GameState
func advanceComputerFlips = state coord flips remaining => remaining
 ||> [nextFlip, ...rest] -> computerAnimState state (setDisc state.board nextFlip (discForTurn Computer)) (Flipping coord flips rest)
 ||> []                  -> setAnimState state (ComputerFlash coord flips 0)

type GameState -> Coord -> (List Coord) -> Int -> GameState
func advanceHumanFlash = state coord flips tick => tick >= flashDuration
 T|> setAnimState state Idle
 F|> setAnimState state (HumanFlash coord flips (tick + 1))

type GameState -> Coord -> (List Coord) -> Int -> GameState
func advanceComputerFlash = state coord flips tick => tick >= flashDuration
 T|> finishComputerAnimation state coord flips
 F|> setAnimState state (ComputerFlash coord flips (tick + 1))

type GameState -> GameState
func startComputerAnim = state => bestComputerMove state.board state.legalMoves
 ||> Some candidate -> beginComputerPreview state candidate.coord (flipsForMove state.board (discForTurn Computer) candidate.coord)
 ||> None           -> makeState state.board state.moveNumber state.lastMove noFlips state.humanCount state.computerCount (advanceTurn state.board Computer)

type GameState -> GameState
func runComputerTurn = state => state.animState
 ||> Idle                              -> startComputerAnim state
 ||> HumanFlash coord flips tick       -> advanceHumanFlash state coord flips tick
 ||> Previewing coord flips tick       -> advanceComputerPreview state coord flips tick
 ||> Flipping coord flips remaining    -> advanceComputerFlips state coord flips remaining
 ||> ComputerFlash coord flips tick    -> advanceComputerFlash state coord flips tick

type GameState -> GameState
func handleComputerTurn = state => computerToAct state.status
 T|> runComputerTurn state
 F|> state

type Event -> GameState -> GameState
func step = event state => event
 ||> Restart          -> initial
 ||> TryPlaceAt coord -> handleTryPlace coord state
 ||> ComputerTurn     -> handleComputerTurn state

type Coord -> Text
func coordLabel = .
 ||> Coord x y -> "({x + 1}, {y + 1})"

type Status -> Text
func statusLabel = .
 ||> Active Human     -> "You are red"
 ||> Active Computer  -> "Blue to move"
 ||> Passed Human     -> "You pass"
 ||> Passed Computer  -> "Blue passes"
 ||> Finished outcome -> outcomeText outcome

type GameState -> Text
func titlebarHintLine = state => (state.status, state.animState)
 ||> (Active Human, _)                      -> "Click a marked cell."
 ||> (Active Computer, HumanFlash _ _ _)     -> "Your move."
 ||> (Active Computer, Previewing _ _ _)     -> "Blue is placing a stone."
 ||> (Active Computer, Flipping _ _ _)       -> "Blue is flipping stones."
 ||> (Active Computer, ComputerFlash _ _ _)  -> "Blue has moved."
 ||> (Active Computer, _)                    -> "Blue is thinking."
 ||> (Passed Human, _)                       -> "Red passes."
 ||> (Passed Computer, _)                    -> "Blue passes."
 ||> (Finished _, _)                         -> "Restart to play again."

type GameState -> Text
func scoreLine = state =>
    "Red {state.humanCount} | Blue {state.computerCount} | Moves {state.moveNumber}"

type GameState -> Text
func lastMoveLine = state => state.lastMove
 ||> Some coord -> lastMoveAt coord
 ||> None       -> "Last move: opening layout"

type Coord -> Text
func lastMoveAt = .
 ||> Coord x y -> "Last move: ({x + 1}, {y + 1})"

type Status -> (List Coord) -> Coord -> Text
func emptyCellLabel = status legalMoves coord => (coordInList coord legalMoves, humanToAct status, computerToAct status)
 ||> (True, True, _)     -> "◌"
 ||> (True, False, True) -> "◍"
 ||> _                   -> "·"

type Option Coord -> Coord -> Bool
func isLastMove = lastMove coord => lastMove
 ||> Some lc -> sameCoord lc coord
 ||> None    -> False

type Int -> Bool
func animStoneVisible = tick =>
    tick % previewBlinkCycleTicks < previewBlinkVisibleTicks

type Int -> Float
func previewOpacityAtTick = tick => animStoneVisible tick
 T|> 1.0
 F|> 0.0

type Coord -> Coord -> (Option Text)
func previewLabelAt = animCoord coord => sameCoord animCoord coord
 T|> Some "🔵"
 F|> None

type AnimState -> Coord -> (Option Text)
func previewLabel = animState coord => animState
 ||> Previewing animCoord _ _ -> previewLabelAt animCoord coord
 ||> _                        -> None

type Coord -> Int -> Coord -> Float
func previewOpacityForCoord = animCoord tick coord => sameCoord animCoord coord
 T|> previewOpacityAtTick tick
 F|> 1.0

type Int -> Float
func placedFlashPhase = tick => tick % placedFlashCycle < placedFlashVisible
 T|> 1.0
 F|> 0.0

type Int -> Float
func placedStoneOpacity = tick => tick < placedFlashDuration
 T|> placedFlashPhase tick
 F|> 1.0

type Int -> Float
func flippedFlashPhase = tick => tick % flippedFlashCycle < flippedFlashVisible
 T|> 1.0
 F|> 0.0

type Int -> Float
func flippedStoneOpacity = tick => tick < flippedFlashDuration
 T|> flippedFlashPhase tick
 F|> 1.0

type Coord -> (List Coord) -> Int -> Coord -> Float
func flashCellOpacity = placed flips tick coord => (sameCoord placed coord, coordInList coord flips)
 ||> (True, _)     -> placedStoneOpacity tick
 ||> (False, True) -> flippedStoneOpacity tick
 ||> _             -> 1.0

type AnimState -> Coord -> Float
func cellOpacity = animState coord => animState
 ||> Previewing animCoord _ tick       -> previewOpacityForCoord animCoord tick coord
 ||> HumanFlash placed flips tick      -> flashCellOpacity placed flips tick coord
 ||> ComputerFlash placed flips tick   -> flashCellOpacity placed flips tick coord
 ||> _                                 -> 1.0

type AnimState -> Coord -> Bool
func cellAnimateOpacity = animState coord => animState
 ||> Previewing animCoord _ _       -> sameCoord animCoord coord
 ||> HumanFlash placed flips _      -> sameCoord placed coord or coordInList coord flips
 ||> ComputerFlash placed flips _   -> sameCoord placed coord or coordInList coord flips
 ||> _                              -> False

type List (List Disc) -> Status -> (List Coord) -> (Option Coord) -> (List Coord) -> Coord -> Text
func baseCellLabel = board status legalMoves lastMove lastFlips coord => discAt board coord
 ||> Red   -> "🔴"
 ||> Blue  -> "🔵"
 ||> Empty -> emptyCellLabel status legalMoves coord

type List (List Disc) -> Status -> (List Coord) -> (Option Coord) -> (List Coord) -> AnimState -> Coord -> Text
func cellLabel = board status legalMoves lastMove lastFlips animState coord => previewLabel animState coord
 ||> Some label -> label
 ||> None       -> baseCellLabel board status legalMoves lastMove lastFlips coord

type GameState -> Coord -> Bool
func cellEnabled = state coord => (humanToAct state.status, coordInList coord state.legalMoves)
 ||> (True, True) -> True
 ||> _            -> False

signal placeCoord : Signal Coord
signal restartClick : Signal Unit

@source timer.every 100
signal computerTick : Signal Unit

signal event : Signal Event

when computerTick _ => event <- ComputerTurn
when placeCoord coord => event <- TryPlaceAt coord
when restartClick _ => event <- Restart

signal state : Signal GameState = event
 +|> initial step

signal phase : Signal Status = state
  |> .status

signal statusText : Signal Text = phase
  |> statusLabel

signal scoreText : Signal Text = state
  |> scoreLine

signal lastMoveText : Signal Text = state
  |> lastMoveLine

signal titlebarHintText : Signal Text = state
  |> titlebarHintLine

value main =
    <Window title="AIVI Reversi">
        <Window.titlebar>
            <HeaderBar showTitleButtons={True}>
                <HeaderBar.start>
                    <Label text={statusText} />
                </HeaderBar.start>
                <HeaderBar.end>
                    <Button label="Restart" onClick={restartClick} compact hasFrame={False} />
                </HeaderBar.end>
            </HeaderBar>
        </Window.titlebar>
        <with value={state} as={currentState}>
            <Box orientation="vertical" spacing={0}>
                <each of={boardIndices} as={y} key={y}>
                    <Box orientation="horizontal" spacing={0}>
                        <each of={boardIndices} as={x} key={x}>
                            <with value={Coord x y} as={coord}>
                                <Button label={cellLabel currentState.board currentState.status currentState.legalMoves currentState.lastMove currentState.lastFlips currentState.animState coord} onClick={placeCoord coord} sensitive={cellEnabled currentState coord} animateOpacity={cellAnimateOpacity currentState.animState coord} opacity={cellOpacity currentState.animState coord} compact hasFrame={False} widthRequest={52} heightRequest={52} />
                            </with>
                        </each>
                    </Box>
                </each>
            </Box>
        </with>
    </Window>

export main
