{
  "$schema": "vscode://schemas/color-theme",
  "name": "AIVI Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1D1F21",
    "editor.foreground": "#C5C8C6",
    "editorCursor.foreground": "#AEAFAD",
    "editor.lineHighlightBackground": "#282C34",
    "editor.selectionBackground": "#373B41",
    "editor.inactiveSelectionBackground": "#2D3038",
    "editor.wordHighlightBackground": "#2D3038",
    "editor.wordHighlightStrongBackground": "#373B41",
    "editorLineNumber.foreground": "#4B4F55",
    "editorLineNumber.activeForeground": "#969896",
    "editorIndentGuide.background1": "#282C34",
    "editorIndentGuide.activeBackground1": "#373B41",
    "editorWhitespace.foreground": "#282C34",
    "editorWidget.background": "#282C34",
    "editorWidget.border": "#373B41",
    "editorSuggestWidget.background": "#282C34",
    "editorSuggestWidget.border": "#373B41",
    "editorSuggestWidget.selectedBackground": "#373B41",
    "editorHoverWidget.background": "#282C34",
    "editorHoverWidget.border": "#373B41",
    "editorBracketMatch.background": "#373B41",
    "editorBracketMatch.border": "#81A2BE",
    "editorError.foreground": "#CC6666",
    "editorWarning.foreground": "#F0C674",
    "editorInfo.foreground": "#81A2BE",
    "editorGutter.addedBackground": "#B5BD68",
    "editorGutter.modifiedBackground": "#F0C674",
    "editorGutter.deletedBackground": "#CC6666",
    "diffEditor.insertedTextBackground": "#1A2418",
    "diffEditor.removedTextBackground": "#2A1A1A",
    "panel.background": "#1D1F21",
    "panel.border": "#282C34",
    "panelTitle.activeBorder": "#81A2BE",
    "panelTitle.activeForeground": "#C5C8C6",
    "panelTitle.inactiveForeground": "#707880",
    "sideBar.background": "#1D1F21",
    "sideBar.foreground": "#C5C8C6",
    "sideBar.border": "#282C34",
    "sideBarTitle.foreground": "#707880",
    "sideBarSectionHeader.background": "#1D1F21",
    "sideBarSectionHeader.foreground": "#C5C8C6",
    "activityBar.background": "#1A1C1E",
    "activityBar.foreground": "#C5C8C6",
    "activityBar.inactiveForeground": "#4B4F55",
    "activityBar.border": "#282C34",
    "activityBarBadge.background": "#81A2BE",
    "activityBarBadge.foreground": "#1D1F21",
    "statusBar.background": "#282C34",
    "statusBar.foreground": "#C5C8C6",
    "statusBar.border": "#1D1F21",
    "statusBar.debuggingBackground": "#CC6666",
    "statusBar.noFolderBackground": "#282C34",
    "statusBarItem.hoverBackground": "#373B41",
    "statusBarItem.remoteBackground": "#81A2BE",
    "statusBarItem.remoteForeground": "#1D1F21",
    "titleBar.activeBackground": "#1D1F21",
    "titleBar.activeForeground": "#C5C8C6",
    "titleBar.inactiveBackground": "#1A1C1E",
    "titleBar.inactiveForeground": "#707880",
    "titleBar.border": "#282C34",
    "tab.activeBackground": "#282C34",
    "tab.activeForeground": "#C5C8C6",
    "tab.inactiveBackground": "#1D1F21",
    "tab.inactiveForeground": "#707880",
    "tab.border": "#1D1F21",
    "tab.activeBorder": "#81A2BE",
    "tab.hoverBackground": "#282C34",
    "editorGroupHeader.tabsBackground": "#1D1F21",
    "editorGroupHeader.tabsBorder": "#1D1F21",
    "breadcrumb.background": "#1D1F21",
    "breadcrumb.foreground": "#969896",
    "breadcrumb.focusForeground": "#C5C8C6",
    "breadcrumb.activeSelectionForeground": "#C5C8C6",
    "terminal.background": "#1D1F21",
    "terminal.foreground": "#C5C8C6",
    "terminal.ansiBlack": "#282C34",
    "terminal.ansiRed": "#CC6666",
    "terminal.ansiGreen": "#B5BD68",
    "terminal.ansiYellow": "#F0C674",
    "terminal.ansiBlue": "#81A2BE",
    "terminal.ansiMagenta": "#B294BB",
    "terminal.ansiCyan": "#8ABEB7",
    "terminal.ansiWhite": "#C5C8C6",
    "terminal.ansiBrightBlack": "#4B4F55",
    "terminal.ansiBrightRed": "#D54E53",
    "terminal.ansiBrightGreen": "#C5C96A",
    "terminal.ansiBrightYellow": "#E7C547",
    "terminal.ansiBrightBlue": "#7AA6DA",
    "terminal.ansiBrightMagenta": "#C397D8",
    "terminal.ansiBrightCyan": "#70C0B1",
    "terminal.ansiBrightWhite": "#EAEAEA",
    "input.background": "#282C34",
    "input.border": "#373B41",
    "input.foreground": "#C5C8C6",
    "input.placeholderForeground": "#4B4F55",
    "inputOption.activeBorder": "#81A2BE",
    "dropdown.background": "#282C34",
    "dropdown.border": "#373B41",
    "dropdown.foreground": "#C5C8C6",
    "list.activeSelectionBackground": "#373B41",
    "list.activeSelectionForeground": "#C5C8C6",
    "list.hoverBackground": "#282C34",
    "list.inactiveSelectionBackground": "#2D3038",
    "list.highlightForeground": "#81A2BE",
    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#37383A80",
    "scrollbarSlider.hoverBackground": "#37383AB0",
    "scrollbarSlider.activeBackground": "#37383AE0",
    "button.background": "#81A2BE",
    "button.foreground": "#1D1F21",
    "button.hoverBackground": "#7AA6DA",
    "badge.background": "#81A2BE",
    "badge.foreground": "#1D1F21",
    "progressBar.background": "#81A2BE",
    "focusBorder": "#81A2BE",
    "selection.background": "#373B41"
  },
  "tokenColors": [

    { "name": "Comment line --",
      "scope": "comment.line.double-dash.aivi",
      "settings": { "foreground": "#707880", "fontStyle": "italic" } },

    { "name": "Comment doc ---",
      "scope": "comment.block.documentation.aivi",
      "settings": { "foreground": "#969896", "fontStyle": "italic" } },

    { "name": "Doc tag @param @returns",
      "scope": "keyword.other.documentation.aivi",
      "settings": { "foreground": "#B294BB", "fontStyle": "italic" } },

    { "name": "Doc tag keyword (structured)",
      "scope": "keyword.other.documentation.tag.aivi",
      "settings": { "foreground": "#B294BB", "fontStyle": "italic" } },

    { "name": "Doc tag param name",
      "scope": "variable.other.documentation.tag.name.aivi",
      "settings": { "foreground": "#DE935F", "fontStyle": "italic" } },

    { "name": "String",
      "scope": "string.quoted.double.aivi",
      "settings": { "foreground": "#B5BD68" } },

    { "name": "String punctuation",
      "scope": ["punctuation.definition.string.begin.aivi",
                "punctuation.definition.string.end.aivi"],
      "settings": { "foreground": "#B5BD68" } },

    { "name": "String interpolation braces",
      "scope": ["punctuation.section.interpolation.begin.aivi",
                "punctuation.section.interpolation.end.aivi"],
      "settings": { "foreground": "#8ABEB7" } },

    { "name": "Escape sequence",
      "scope": "constant.character.escape.aivi",
      "settings": { "foreground": "#8ABEB7" } },

    { "name": "Number integer",
      "scope": ["constant.numeric.integer.aivi", "constant.numeric.float.aivi"],
      "settings": { "foreground": "#DE935F" } },

    { "name": "Number unit suffix (5s, 250ms)",
      "scope": "keyword.other.unit.aivi",
      "settings": { "foreground": "#F0C674" } },

    { "name": "Declaration keywords (type value fun signal source result view adapter data class domain instance provider)",
      "scope": [
        "keyword.declaration.type.aivi",
        "keyword.declaration.value.aivi",
        "keyword.declaration.fun.aivi",
        "keyword.declaration.signal.aivi",
        "keyword.declaration.source.aivi",
        "keyword.declaration.result.aivi",
        "keyword.declaration.view.aivi",
        "keyword.declaration.adapter.aivi",
        "keyword.declaration.data.aivi",
        "keyword.declaration.class.aivi",
        "keyword.declaration.instance.aivi",
        "keyword.declaration.domain.aivi",
        "keyword.declaration.provider.aivi"
      ],
      "settings": { "foreground": "#81A2BE" } },

    { "name": "use keyword",
      "scope": "keyword.control.import.aivi",
      "settings": { "foreground": "#81A2BE" } },

    { "name": "export keyword",
      "scope": "keyword.control.export.aivi",
      "settings": { "foreground": "#B294BB", "fontStyle": "bold" } },

    { "name": "Built-in type keywords (with as of key on pattern value match when if)",
      "scope": "keyword.other.aivi",
      "settings": { "foreground": "#81A2BE", "fontStyle": "italic" } },

    { "name": "Type name / class name",
      "scope": ["entity.name.type.aivi", "entity.name.class.aivi"],
      "settings": { "foreground": "#F0C674" } },

    { "name": "Type parameter (lowercase after type keyword)",
      "scope": "variable.parameter.type.aivi",
      "settings": { "foreground": "#C5C8C6" } },

    { "name": "Function name (fun / sig)",
      "scope": ["entity.name.function.aivi", "entity.name.variable.signal.aivi"],
      "settings": { "foreground": "#C5C8C6", "fontStyle": "bold" } },

    { "name": "Value name (val)",
      "scope": "entity.name.variable.aivi",
      "settings": { "foreground": "#C5C8C6" } },

    { "name": "Domain / provider / namespace name",
      "scope": ["entity.name.namespace.aivi", "entity.name.module.aivi"],
      "settings": { "foreground": "#8ABEB7" } },

    { "name": "Constructor (uppercase identifier)",
      "scope": "entity.name.tag.constructor.aivi",
      "settings": { "foreground": "#F0C674" } },

    { "name": "Built-in value constants (True False None Some Ok Err Valid Invalid)",
      "scope": "support.constant.builtin.aivi",
      "settings": { "foreground": "#F0C674" } },

    { "name": "Built-in types (Int Bool Text List ...)",
      "scope": "support.type.builtin.aivi",
      "settings": { "foreground": "#81A2BE" } },

    { "name": "Type annotations outside records",
      "scope": "meta.type.annotation.aivi",
      "settings": { "foreground": "#4B4F55" } },

    { "name": "Type annotation separator outside records",
      "scope": "punctuation.separator.type.annotation.declaration.aivi",
      "settings": { "foreground": "#4B4F55" } },

    { "name": "Labeled parameter #name",
      "scope": "variable.parameter.labeled.aivi",
      "settings": { "foreground": "#B294BB" } },

    { "name": "Labeled parameter # sigil",
      "scope": "punctuation.definition.parameter.aivi",
      "settings": { "foreground": "#B294BB" } },

    { "name": "Import names",
      "scope": "variable.other.import.aivi",
      "settings": { "foreground": "#C5C8C6" } },

    { "name": "Decorator @ sigil",
      "scope": "punctuation.definition.decorator.aivi",
      "settings": { "foreground": "#B294BB" } },

    { "name": "Decorator @source keyword",
      "scope": "keyword.decorator.source.aivi",
      "settings": { "foreground": "#B294BB", "fontStyle": "bold" } },

    { "name": "Decorator @recur keyword",
      "scope": "keyword.decorator.recur.aivi",
      "settings": { "foreground": "#CC6666", "fontStyle": "bold" } },

    { "name": "Decorator generic label (@myDecorator)",
      "scope": "entity.name.label.decorator.aivi",
      "settings": { "foreground": "#B294BB" } },

    { "name": "Decorator provider name (after @source)",
      "scope": "entity.name.label.provider.aivi",
      "settings": { "foreground": "#8ABEB7" } },

    { "name": "Decorator method name (.get .every ...)",
      "scope": "entity.name.label.method.aivi",
      "settings": { "foreground": "#8ABEB7" } },

    { "name": "Accessor dot in decorator",
      "scope": "punctuation.accessor.aivi",
      "settings": { "foreground": "#969896" } },

    { "name": "Pipe — transform |>",
      "scope": "keyword.operator.pipe.transform.aivi",
      "settings": { "foreground": "#DE935F" } },

    { "name": "Pipe — gate ?|>",
      "scope": "keyword.operator.pipe.gate.aivi",
      "settings": { "foreground": "#F0C674" } },

    { "name": "Pipe — case ||>",
      "scope": "keyword.operator.pipe.case.aivi",
      "settings": { "foreground": "#B294BB" } },

    { "name": "Pipe — map *|>",
      "scope": "keyword.operator.pipe.map.aivi",
      "settings": { "foreground": "#8ABEB7" } },

    { "name": "Pipe — apply &|>",
      "scope": "keyword.operator.pipe.apply.aivi",
      "settings": { "foreground": "#B5BD68" } },

    { "name": "Pipe — recur start @|>",
      "scope": "keyword.operator.pipe.recur-start.aivi",
      "settings": { "foreground": "#CC6666" } },

    { "name": "Pipe — recur step <|@",
      "scope": "keyword.operator.pipe.recur-step.aivi",
      "settings": { "foreground": "#CC6666" } },

    { "name": "Pipe — fanin <|*",
      "scope": "keyword.operator.pipe.fanin.aivi",
      "settings": { "foreground": "#7AA6DA" } },

    { "name": "Pipe — truthy T|>",
      "scope": "keyword.operator.pipe.truthy.aivi",
      "settings": { "foreground": "#B5BD68" } },

    { "name": "Pipe — falsy F|>",
      "scope": "keyword.operator.pipe.falsy.aivi",
      "settings": { "foreground": "#CC6666" } },

    { "name": "Pipe — tap |",
      "scope": "keyword.operator.pipe.tap.aivi",
      "settings": { "foreground": "#969896" } },

    { "name": "Arrow => (match arm / lambda body)",
      "scope": "keyword.operator.arrow.fat.aivi",
      "settings": { "foreground": "#DE935F" } },

    { "name": "Arrow -> (function type)",
      "scope": "keyword.operator.arrow.thin.aivi",
      "settings": { "foreground": "#DE935F" } },

    { "name": "Equality == !=",
      "scope": "keyword.operator.comparison.aivi",
      "settings": { "foreground": "#C5C8C6" } },

    { "name": "Assignment =",
      "scope": "keyword.operator.assignment.aivi",
      "settings": { "foreground": "#C5C8C6" } },

    { "name": "Attribute = in markup",
      "scope": "keyword.operator.assign.aivi",
      "settings": { "foreground": "#4B4F55" } },

    { "name": "Type annotation :",
      "scope": "keyword.operator.type-annotation.aivi",
      "settings": { "foreground": "#969896" } },

    { "name": "Dot projection",
      "scope": "keyword.operator.projection.aivi",
      "settings": { "foreground": "#969896" } },

    { "name": "Arithmetic + - * /",
      "scope": "keyword.operator.arithmetic.aivi",
      "settings": { "foreground": "#C5C8C6" } },

    { "name": "Record / struct field key",
      "scope": "variable.other.property.aivi",
      "settings": { "foreground": "#8ABEB7" } },

    { "name": "Markup tag punctuation < > </ />",
      "scope": "punctuation.definition.tag.aivi",
      "settings": { "foreground": "#4B4F55" } },

    { "name": "Markup control element tag (<show> <each> <match> ...)",
      "scope": "entity.name.tag.control.aivi",
      "settings": { "foreground": "#8ABEB7", "fontStyle": "bold" } },

    { "name": "Markup user component tag (<MyComponent>)",
      "scope": "entity.name.tag.component.aivi",
      "settings": { "foreground": "#F0C674" } },

    { "name": "Markup HTML/GTK/XML tag (<div> <gtk:Box>)",
      "scope": "entity.name.tag.html.aivi",
      "settings": { "foreground": "#81A2BE" } },

    { "name": "Markup attribute name",
      "scope": "entity.other.attribute-name.aivi",
      "settings": { "foreground": "#B294BB" } }

  ],
  "semanticTokenColors": {
    "type":      { "foreground": "#F0C674" },
    "class":     { "foreground": "#F0C674" },
    "interface": { "foreground": "#8ABEB7" },
    "enum":      { "foreground": "#F0C674" },
    "enumMember":{ "foreground": "#F0C674" },
    "function":  { "foreground": "#C5C8C6", "bold": true },
    "method":    { "foreground": "#C5C8C6", "bold": true },
    "variable":  { "foreground": "#C5C8C6" },
    "parameter": { "foreground": "#C5C8C6" },
    "property":  { "foreground": "#8ABEB7" },
    "namespace": { "foreground": "#8ABEB7" },
    "keyword":   { "foreground": "#81A2BE" },
    "number":    { "foreground": "#DE935F" },
    "string":    { "foreground": "#B5BD68" },
    "regexp":    { "foreground": "#8ABEB7" },
    "operator":  { "foreground": "#C5C8C6" },
    "comment":   { "foreground": "#707880", "italic": true },
    "macro":     { "foreground": "#CC6666" },
    "decorator": { "foreground": "#B294BB" }
  }
}
