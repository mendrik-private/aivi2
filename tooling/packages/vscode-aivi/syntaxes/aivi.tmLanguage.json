{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "aivi",
  "displayName": "AIVI",
  "scopeName": "source.aivi",
  "fileTypes": [".aivi"],
  "patterns": [
    { "include": "#pipe-operators" },
    { "include": "#doc-comment" },
    { "include": "#block-comment" },
    { "include": "#line-comment" },
    { "include": "#string" },
    { "include": "#decorator" },
    { "include": "#annotated-signatures" },
    { "include": "#declaration" },
    { "include": "#pipe-stage-head" },
    { "include": "#function-call-head" },
    { "include": "#markup" },
    { "include": "#record-key" },
    { "include": "#type-expression" },
    { "include": "#operators" },
    { "include": "#number" },
    { "include": "#labeled-param" },
    { "include": "#constructor" },
    { "include": "#builtin-keyword" }
  ],
  "repository": {

    "doc-comment": {
      "name": "comment.block.documentation.aivi",
      "begin": "/\\*\\*",
      "end": "\\*\\*/",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.aivi" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.aivi" }
      },
      "patterns": [
        {
          "match": "@(param|returns|return|since|deprecated|see|throws|example)\\b",
          "name": "keyword.other.documentation.aivi"
        },
        {
          "match": "(@\\w+)\\s+(\\w+)",
          "captures": {
            "1": { "name": "keyword.other.documentation.tag.aivi" },
            "2": { "name": "variable.other.documentation.tag.name.aivi" }
          }
        },
        {
          "match": "\\[([A-Za-z][a-zA-Z0-9_.]*)]",
          "captures": {
            "1": { "name": "entity.name.type.aivi" }
          }
        }
      ]
    },

    "block-comment": {
      "name": "comment.block.aivi",
      "begin": "/\\*",
      "end": "\\*/",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.aivi" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.aivi" }
      }
    },

    "line-comment": {
      "name": "comment.line.double-slash.aivi",
      "match": "//.*$"
    },

    "string": {
      "name": "string.quoted.double.aivi",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.aivi" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.aivi" } },
      "patterns": [
        {
          "name": "meta.interpolation.aivi",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.aivi" } },
          "endCaptures":   { "0": { "name": "punctuation.section.interpolation.end.aivi" } },
          "patterns": [{ "include": "$self" }]
        },
        { "name": "constant.character.escape.aivi", "match": "\\\\." }
      ]
    },

    "decorator": {
      "patterns": [
        {
          "comment": "@source provider.method",
          "match": "(@)(source)\\s+([a-z][a-zA-Z0-9_]*)(\\.)((?:get|post|put|delete|patch|every|watch|[a-z][a-zA-Z0-9_]*))",
          "captures": {
            "1": { "name": "punctuation.definition.decorator.aivi" },
            "2": { "name": "keyword.decorator.source.aivi" },
            "3": { "name": "entity.name.label.provider.aivi" },
            "4": { "name": "punctuation.accessor.aivi" },
            "5": { "name": "entity.name.label.method.aivi" }
          }
        },
        {
          "comment": "@recur.timer / @recur.backoff",
          "match": "(@)(recur)(\\.)(timer|backoff|interval|schedule)",
          "captures": {
            "1": { "name": "punctuation.definition.decorator.aivi" },
            "2": { "name": "keyword.decorator.recur.aivi" },
            "3": { "name": "punctuation.accessor.aivi" },
            "4": { "name": "entity.name.label.method.aivi" }
          }
        },
        {
          "comment": "generic @decorator — must start with a letter (not | which belongs to @|>)",
          "match": "(@)([a-zA-Z][a-zA-Z0-9_.]*)",
          "captures": {
            "1": { "name": "punctuation.definition.decorator.aivi" },
            "2": { "name": "entity.name.label.decorator.aivi" }
          }
        }
      ]
    },

    "annotated-signatures": {
      "patterns": [
        { "include": "#type-signature" },
        { "include": "#fun-signature" },
        { "include": "#value-signature" },
        { "include": "#signal-signature" },
        { "include": "#source-signature" },
        { "include": "#result-signature" },
        { "include": "#view-signature" },
        { "include": "#adapter-signature" },
        { "include": "#class-annotation-block" },
        { "include": "#domain-annotation-block" },
        { "include": "#provider-annotation-block" }
      ]
    },

    "type-signature": {
      "begin": "^\\s*(type)\\b(?!\\s+[A-Z][a-zA-Z0-9_]*(?:\\s+[a-z][a-zA-Z0-9_]*)*\\s*=)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.type.aivi" }
      },
      "end": "$",
      "name": "meta.type.signature.aivi",
      "patterns": [
        { "include": "#type-surface" }
      ]
    },

    "fun-signature": {
      "begin": "\\b(func|fun)\\s+([a-z_][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.func.aivi" },
        "2": { "name": "entity.name.function.aivi" }
      },
      "end": "(?=\\s*=>|$)",
      "patterns": [
        { "include": "#fun-type-annotation" },
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.parameter.function.aivi" }
          }
        }
      ]
    },

    "fun-type-annotation": {
      "begin": ":",
      "beginCaptures": {
        "0": { "name": "punctuation.separator.type.annotation.declaration.aivi" }
      },
      "end": "(?=\\s+[a-z_][a-zA-Z0-9_]*\\s*:(?!:)|\\s*=>|$)",
      "name": "meta.type.annotation.aivi",
      "patterns": [
        { "include": "#type-surface" }
      ]
    },

    "assignment-type-annotation": {
      "begin": ":",
      "beginCaptures": {
        "0": { "name": "punctuation.separator.type.annotation.declaration.aivi" }
      },
      "end": "(?=\\s*=|$)",
      "name": "meta.type.annotation.aivi",
      "patterns": [
        { "include": "#type-surface" }
      ]
    },

    "value-signature": {
      "begin": "\\b(value)\\s+([a-z_][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.value.aivi" },
        "2": { "name": "entity.name.variable.aivi" }
      },
      "end": "(?=\\s*=|$)",
      "patterns": [
        { "include": "#assignment-type-annotation" }
      ]
    },

    "signal-signature": {
      "begin": "\\b(signal)\\s+([a-z_][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.signal.aivi" },
        "2": { "name": "entity.name.variable.signal.aivi" }
      },
      "end": "(?=\\s*=|$)",
      "patterns": [
        { "include": "#assignment-type-annotation" }
      ]
    },

    "source-signature": {
      "begin": "\\b(source)\\s+([a-z_][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.source.aivi" },
        "2": { "name": "entity.name.variable.source.aivi" }
      },
      "end": "(?=\\s*=|$)",
      "patterns": [
        { "include": "#assignment-type-annotation" }
      ]
    },

    "result-signature": {
      "begin": "\\b(result)\\s+([a-z_][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.result.aivi" },
        "2": { "name": "entity.name.variable.aivi" }
      },
      "end": "(?=\\s*=|$)",
      "patterns": [
        { "include": "#assignment-type-annotation" }
      ]
    },

    "view-signature": {
      "begin": "\\b(view)\\s+([A-Z][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.view.aivi" },
        "2": { "name": "entity.name.type.aivi" }
      },
      "end": "(?=\\s*=|$)",
      "patterns": [
        { "include": "#assignment-type-annotation" }
      ]
    },

    "adapter-signature": {
      "begin": "\\b(adapter)\\s+([a-z_][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.adapter.aivi" },
        "2": { "name": "entity.name.function.aivi" }
      },
      "end": "(?=\\s*=|$)",
      "patterns": [
        { "include": "#assignment-type-annotation" }
      ]
    },

    "class-annotation-block": {
      "begin": "\\b(class)\\b(?:\\s+[^\\n]+?=>\\s+)?([A-Z][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.class.aivi" },
        "2": { "name": "entity.name.class.aivi" }
      },
      "end": "(?=\\n(?![ \\t])|\\z)",
      "patterns": [
        { "include": "#line-comment" },
        {
          "match": "^([ \\t]+(?:\\([^\\n]+?\\)|[a-z_][a-zA-Z0-9_]*))(\\s*:\\s*)([^\\n]+)$",
          "captures": {
            "2": { "name": "punctuation.separator.type.annotation.declaration.aivi" },
            "3": { "name": "meta.type.annotation.aivi" }
          }
        }
      ]
    },

    "domain-annotation-block": {
      "begin": "\\b(domain)\\s+([A-Z][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.domain.aivi" },
        "2": { "name": "entity.name.type.aivi" }
      },
      "end": "(?=\\n(?![ \\t])|\\z)",
      "patterns": [
        { "include": "#line-comment" },
        {
          "match": "^([ \\t]+(?:literal\\s+[a-z_][a-zA-Z0-9_]*|\\([^\\n]+?\\)|[a-z_][a-zA-Z0-9_]*))(\\s*:\\s*)([^\\n]+)$",
          "captures": {
            "2": { "name": "punctuation.separator.type.annotation.declaration.aivi" },
            "3": { "name": "meta.type.annotation.aivi" }
          }
        }
      ]
    },

    "provider-annotation-block": {
      "begin": "\\b(provider)\\s+([a-z][a-zA-Z0-9_.]*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.provider.aivi" },
        "2": { "name": "entity.name.label.provider.aivi" }
      },
      "end": "(?=\\n(?![ \\t])|\\z)",
      "patterns": [
        { "include": "#line-comment" },
        {
          "match": "^([ \\t]+(?:option|argument)\\s+[a-z_][a-zA-Z0-9_]*)(\\s*:\\s*)([^\\n]+)$",
          "captures": {
            "2": { "name": "punctuation.separator.type.annotation.declaration.aivi" },
            "3": { "name": "meta.type.annotation.aivi" }
          }
        }
      ]
    },

    "declaration": {
      "patterns": [
        {
          "comment": "type Name <params> = ...",
          "begin": "^\\s*(type)\\b(?=\\s+[A-Z][a-zA-Z0-9_]*(?:\\s+[a-z][a-zA-Z0-9_]*)*(?:\\s*=|$))",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.type.aivi" }
          },
          "end": "$",
          "name": "meta.type.declaration.aivi",
          "patterns": [
            { "include": "#type-surface" }
          ]
        },
        {
          "comment": "class Name TypeParam",
          "match": "\\b(class)\\s+([A-Z][a-zA-Z0-9_]*)((?:\\s+[a-z][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.declaration.class.aivi" },
            "2": { "name": "entity.name.class.aivi" },
            "3": { "name": "variable.parameter.type.aivi" }
          }
        },
        {
          "comment": "instance Class Type",
          "match": "\\b(instance)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.instance.aivi" },
            "2": { "name": "entity.name.type.aivi" }
          }
        },
        {
          "comment": "data Name — ADT declaration",
          "match": "\\b(data)\\s+([A-Z][a-zA-Z0-9_]*)((?:\\s+[a-z][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.declaration.data.aivi" },
            "2": { "name": "entity.name.type.aivi" },
            "3": { "name": "variable.parameter.type.aivi" }
          }
        },
        {
          "comment": "func name — function declaration",
          "match": "\\b(func|fun)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.func.aivi" },
            "2": { "name": "entity.name.function.aivi" }
          }
        },
        {
          "comment": "value name — constant declaration",
          "match": "\\b(value)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.value.aivi" },
            "2": { "name": "entity.name.variable.aivi" }
          }
        },
        {
          "comment": "signal name — reactive signal declaration",
          "match": "\\b(signal)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.signal.aivi" },
            "2": { "name": "entity.name.variable.signal.aivi" }
          }
        },
        {
          "comment": "source name — source-backed signal declaration",
          "match": "\\b(source)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.source.aivi" },
            "2": { "name": "entity.name.variable.source.aivi" }
          }
        },
        {
          "comment": "result name — graph-assembly result",
          "match": "\\b(result)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.result.aivi" },
            "2": { "name": "entity.name.variable.aivi" }
          }
        },
        {
          "comment": "view name — markup view declaration",
          "match": "\\b(view)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.view.aivi" },
            "2": { "name": "entity.name.type.aivi" }
          }
        },
        {
          "comment": "adapter name — adapter declaration",
          "match": "\\b(adapter)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.adapter.aivi" },
            "2": { "name": "entity.name.function.aivi" }
          }
        },
        {
          "comment": "domain Name",
          "match": "\\b(domain)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.domain.aivi" },
            "2": { "name": "entity.name.type.aivi" }
          }
        },
        {
          "comment": "provider path.name",
          "match": "\\b(provider)\\s+([a-z][a-zA-Z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.declaration.provider.aivi" },
            "2": { "name": "entity.name.label.provider.aivi" }
          }
        },
        {
          "comment": "use module.path",
          "begin": "\\b(use)\\s+",
          "beginCaptures": { "1": { "name": "keyword.control.import.aivi" } },
          "end": "(?=\\n(?![ \\t]))",
          "patterns": [
            {
              "match": "([a-z][a-zA-Z0-9_]*)(?:\\.[a-z][a-zA-Z0-9_]*)+",
              "name": "entity.name.namespace.aivi"
            },
            {
              "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
              "name": "entity.name.type.aivi"
            },
            {
              "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b",
              "name": "variable.other.import.aivi"
            },
            { "include": "#line-comment" },
            { "include": "#block-comment" }
          ]
        },
        {
          "comment": "export name",
          "match": "\\b(export)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.export.aivi" },
            "2": { "name": "entity.name.variable.aivi" }
          }
        },
        {
          "comment": "hoist module.path with optional kind filters and hiding clause",
          "begin": "\\b(hoist)\\s+",
          "beginCaptures": { "1": { "name": "keyword.control.import.aivi" } },
          "end": "(?=\\n(?![ \\t]))",
          "patterns": [
            {
              "match": "([a-z][a-zA-Z0-9_]*)(?:\\.[a-z][a-zA-Z0-9_]*)+",
              "name": "entity.name.namespace.aivi"
            },
            {
              "match": "\\b(hiding)\\b",
              "name": "keyword.control.import.aivi"
            },
            {
              "match": "\\b(func|value|signal|type|domain|class)\\b",
              "name": "storage.type.aivi"
            },
            {
              "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b",
              "name": "variable.other.import.aivi"
            },
            { "include": "#line-comment" },
            { "include": "#block-comment" }
          ]
        }
      ]
    },

    "function-call-head": {
      "patterns": [
        {
          "comment": "lowercase call heads followed by arguments",
          "match": "(?<![@.])\\b(?!(?:func|fun|value|signal|source|result|type|class|instance|domain|provider|use|export|hoist|with|require|when|as|pattern|of|on|key)\\b)([a-z_][a-zA-Z0-9_]*)\\b(?=\\s+(?:[#a-z_][a-zA-Z0-9_]*|\\(|\\[|\\{|\\\"|-?\\d|<))",
          "captures": {
            "1": { "name": "entity.name.function.call.aivi" }
          }
        }
      ]
    },

    "pipe-stage-head": {
      "patterns": [
        {
          "comment": "signal source names in ||> merge arms — NOT function calls",
          "match": "(?<=\\|\\|>\\s)([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.other.aivi" }
          }
        },
        {
          "comment": "pipe stage function heads (tap | requires line-start to avoid matching merge separator)",
          "match": "(?:(?<=^\\s*\\|\\s)|(?<=\\|>\\s)|(?<=\\?\\|>\\s)|(?<=\\*\\|>\\s)|(?<=&\\|>\\s)|(?<=T\\|>\\s)|(?<=F\\|>\\s)|(?<=@\\|>\\s)|(?<=<\\|@\\s)|(?<=<\\|\\*\\s))([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.function.call.aivi" }
          }
        }
      ]
    },

    "pipe-operators": {
      "comment": "Ordered longest-first. Must be included FIRST in top-level patterns so @|>, T|>, F|> are never split.",
      "patterns": [
        {
          "name": "keyword.operator.pipe.fanin.aivi",
          "match": "<\\|\\*"
        },
        {
          "name": "keyword.operator.pipe.recur-step.aivi",
          "match": "<\\|@"
        },
        {
          "name": "keyword.operator.pipe.case.aivi",
          "match": "\\|\\|>"
        },
        {
          "name": "keyword.operator.pipe.gate.aivi",
          "match": "\\?\\|>"
        },
        {
          "name": "keyword.operator.pipe.map.aivi",
          "match": "\\*\\|>"
        },
        {
          "name": "keyword.operator.pipe.apply.aivi",
          "match": "&\\|>"
        },
        {
          "name": "keyword.operator.pipe.recur-start.aivi",
          "match": "@\\|>"
        },
        {
          "name": "keyword.operator.pipe.truthy.aivi",
          "match": "T\\|>"
        },
        {
          "name": "keyword.operator.pipe.falsy.aivi",
          "match": "F\\|>"
        },
        {
          "name": "keyword.operator.pipe.transform.aivi",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.pipe.tap.aivi",
          "match": "(?<![<\\?\\*&@|])\\|(?![>@\\*])"
        }
      ]
    },

    "markup": {
      "patterns": [
        {
          "comment": "closing control tag  </show> </each> ...",
          "match": "(</)\\s*(show|each|match|case|fragment|empty|with|gate)\\s*(>)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.aivi" },
            "2": { "name": "entity.name.tag.control.aivi" },
            "3": { "name": "punctuation.definition.tag.aivi" }
          }
        },
        {
          "comment": "closing component tag  </MyComponent>",
          "match": "(</)([A-Z][a-zA-Z0-9_]*)(>)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.aivi" },
            "2": { "name": "entity.name.tag.component.aivi" },
            "3": { "name": "punctuation.definition.tag.aivi" }
          }
        },
        {
          "comment": "closing html/gtk/xml tag  </div> </gtk:Box>",
          "match": "(</)([a-z][a-zA-Z0-9_:-]*)(>)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.aivi" },
            "2": { "name": "entity.name.tag.html.aivi" },
            "3": { "name": "punctuation.definition.tag.aivi" }
          }
        },
        {
          "comment": "opening control elements  <show <each <match ...",
          "begin": "(<)(show|each|match|case|fragment|empty|with|gate)(?=[\\s>/])",
          "end": "/?>",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.aivi" },
            "2": { "name": "entity.name.tag.control.aivi" }
          },
          "endCaptures": { "0": { "name": "punctuation.definition.tag.aivi" } },
          "patterns": [{ "include": "#markup-attributes" }]
        },
        {
          "comment": "opening user component  <MyComponent",
          "begin": "(<)([A-Z][a-zA-Z0-9_]*)(?=[\\s>/])",
          "end": "/?>",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.aivi" },
            "2": { "name": "entity.name.tag.component.aivi" }
          },
          "endCaptures": { "0": { "name": "punctuation.definition.tag.aivi" } },
          "patterns": [{ "include": "#markup-attributes" }]
        },
        {
          "comment": "opening html/gtk/xml element  <div <gtk:Box",
          "begin": "(<)([a-z][a-zA-Z0-9_:-]*)(?=[\\s>/])",
          "end": "/?>",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.aivi" },
            "2": { "name": "entity.name.tag.html.aivi" }
          },
          "endCaptures": { "0": { "name": "punctuation.definition.tag.aivi" } },
          "patterns": [{ "include": "#markup-attributes" }]
        }
      ]
    },

    "markup-attributes": {
      "patterns": [
        {
          "begin": "([a-zA-Z_][a-zA-Z0-9_-]*)\\s*(=)\\s*(\\{)",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.aivi" },
            "2": { "name": "keyword.operator.assign.aivi" },
            "3": { "name": "punctuation.section.interpolation.begin.aivi" }
          },
          "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.aivi" } },
          "patterns": [{ "include": "$self" }]
        },
        {
          "begin": "([a-zA-Z_][a-zA-Z0-9_-]*)\\s*(=)\\s*(\")",
          "end": "\"",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.aivi" },
            "2": { "name": "keyword.operator.assign.aivi" },
            "3": { "name": "punctuation.definition.string.begin.aivi" }
          },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.aivi" } },
          "contentName": "string.quoted.double.aivi"
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\b(?!\\s*=)",
          "name": "entity.other.attribute-name.aivi"
        }
      ]
    },

    "record-key": {
      "comment": "Identifier immediately followed by : with no space — record/struct field. Excludes 'name : Type' style annotations which use a space.",
      "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=:(?!:))",
      "captures": {
        "1": { "name": "variable.other.property.aivi" }
      }
    },

    "type-expression": {
      "patterns": [
        {
          "comment": "built-in types",
          "name": "support.type.builtin.aivi",
          "match": "\\b(Int|Float|Decimal|BigInt|Bool|Text|Unit|Bytes|List|Map|Set|Option|Result|Validation|Signal|Task|Regex)\\b"
        },
        {
          "comment": "built-in value constants — True False None Some Ok Err Valid Invalid",
          "name": "support.constant.builtin.aivi",
          "match": "\\b(Some|None|Ok|Err|True|False|Valid|Invalid)\\b"
        }
      ]
    },

    "type-surface": {
      "patterns": [
        { "include": "#line-comment" },
        { "include": "#block-comment" },
        { "include": "#record-key" },
        { "include": "#type-expression" },
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.aivi" }
          }
        },
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.parameter.type.aivi" }
          }
        },
        { "include": "#operators" }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.fat.aivi",
          "match": "=>"
        },
        {
          "name": "keyword.operator.arrow.thin.aivi",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.aivi",
          "match": "==|!="
        },
        {
          "name": "keyword.operator.comparison.aivi",
          "match": "[<>]=?"
        },
        {
          "comment": "assignment = not part of == => !=",
          "name": "keyword.operator.assignment.aivi",
          "match": "(?<![=!<>])=(?![>=])"
        },
        {
          "name": "keyword.operator.type-annotation.aivi",
          "match": ":"
        },
        {
          "name": "keyword.operator.projection.aivi",
          "match": "\\."
        },
        {
          "name": "keyword.operator.arithmetic.aivi",
          "match": "[+\\-*\\/]"
        }
      ]
    },

    "number": {
      "patterns": [
        {
          "comment": "suffix literal: 250ms 5s 1min",
          "match": "\\b([0-9][0-9_]*)([a-z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "constant.numeric.integer.aivi" },
            "2": { "name": "keyword.other.unit.aivi" }
          }
        },
        {
          "name": "constant.numeric.float.aivi",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.aivi",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },

    "labeled-param": {
      "match": "(#)([a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.definition.parameter.aivi" },
        "2": { "name": "variable.parameter.labeled.aivi" }
      }
    },

    "constructor": {
      "comment": "Uppercase identifiers not matched by type-expression",
      "name": "entity.name.tag.constructor.aivi",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },

    "builtin-keyword": {
      "match": "\\b(with|as|of|key|on|pattern|and|or|not|if|then|else|let|in|match|when)\\b",
      "name": "keyword.other.aivi"
    }
  }
}
